// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Rol {
  id_rol   Int       @id @default(autoincrement())
  nombre   String    @db.VarChar(50)
  usuarios Usuario[]

  @@map("rol")
}

model Usuario {
  id_usuario Int     @id @default(autoincrement())
  nombre     String  @db.VarChar(50)
  apellido   String  @db.VarChar(50)
  correo     String  @unique @db.VarChar(100)
  contrasena String  @db.VarChar(255)
  activo     Boolean @default(true)
  id_rol     Int

  rol        Rol                @relation(fields: [id_rol], references: [id_rol])
  consultor  Consultor?
  bitacoras  Bitacora[]
  log_montos LogMontoProyecto[]

  @@map("usuarios")
}

model Empresa {
  id_empresa Int       @id @default(autoincrement())
  nombre     String    @db.VarChar(100)
  direccion  String?   @db.VarChar(100)
  clientes   Cliente[]

  @@map("empresa")
}

model EstadoCliente {
  id_estado_cliente Int       @id @default(autoincrement())
  estado            String    @db.VarChar(50)
  clientes          Cliente[]

  @@map("estado_cliente")
}

model Cliente {
  id_cliente        Int     @id @default(autoincrement())
  nombre            String  @db.VarChar(100)
  apellido          String  @db.VarChar(100)
  correo            String? @unique @db.VarChar(100)
  telefono          String? @db.VarChar(20)
  id_empresa        Int
  id_estado_cliente Int

  empresa        Empresa       @relation(fields: [id_empresa], references: [id_empresa])
  estado_cliente EstadoCliente @relation(fields: [id_estado_cliente], references: [id_estado_cliente])
  proyectos      Proyecto[]

  @@map("clientes")
}

model Consultor {
  id_consultor Int     @id @default(autoincrement())
  nombre       String  @db.VarChar(100)
  telefono     String? @db.VarChar(20)
  correo       String? @unique @db.VarChar(100)
  activo       Boolean @default(true)
  id_usuario   Int?    @unique

  usuario   Usuario?   @relation(fields: [id_usuario], references: [id_usuario])
  proyectos Proyecto[]

  @@map("consultores")
}

model EstadoProyecto {
  id_estado_proyecto Int        @id @default(autoincrement())
  estado             String     @db.VarChar(50)
  proyectos          Proyecto[]
  bitacoras          Bitacora[]

  @@map("estado_proyecto")
}

model Proyecto {
  id_proyecto        Int       @id @default(autoincrement())
  no_proyecto        String    @unique @db.VarChar(20)
  nombre             String?   @db.VarChar(100)
  descripcion        String?
  fecha_inicio       DateTime  @db.Date
  fecha_fin          DateTime? @db.Date
  id_cliente         Int
  id_consultor       Int
  id_estado_proyecto Int

  cliente         Cliente            @relation(fields: [id_cliente], references: [id_cliente])
  consultor       Consultor          @relation(fields: [id_consultor], references: [id_consultor])
  estado_proyecto EstadoProyecto     @relation(fields: [id_estado_proyecto], references: [id_estado_proyecto])
  bitacoras       Bitacora[]
  log_montos      LogMontoProyecto[]

  @@map("proyectos")
}

model Prioridad {
  id_prioridad     Int        @id @default(autoincrement())
  nombre_prioridad String     @db.VarChar(50)
  bitacoras        Bitacora[]

  @@map("prioridad")
}

model Bitacora {
  id_bitacora        Int      @id @default(autoincrement())
  fecha              DateTime @db.Date
  observaciones      String?
  id_estado_proyecto Int
  id_proyecto        Int
  id_usuario         Int
  id_prioridad       Int

  estado_proyecto EstadoProyecto @relation(fields: [id_estado_proyecto], references: [id_estado_proyecto])
  proyecto        Proyecto       @relation(fields: [id_proyecto], references: [id_proyecto])
  usuario         Usuario        @relation(fields: [id_usuario], references: [id_usuario])
  prioridad       Prioridad      @relation(fields: [id_prioridad], references: [id_prioridad])

  @@map("bitacora")
}

model LogMontoProyecto {
  id_log_montos Int      @id @default(autoincrement())
  monto         Decimal  @db.Decimal(12, 2)
  observaciones String?
  fecha         DateTime @db.Date
  id_proyecto   Int
  id_usuario    Int

  proyecto Proyecto @relation(fields: [id_proyecto], references: [id_proyecto])
  usuario  Usuario  @relation(fields: [id_usuario], references: [id_usuario])

  @@map("log_montos_proyectos")
}
